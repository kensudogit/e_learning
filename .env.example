# Application
APP_ENV=development
DEBUG=true

# Database (local Docker / Amazon RDS in production)
DATABASE_URL=postgresql+asyncpg://elearning:elearning@localhost:5433/elearning

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT (local only — production uses Cognito)
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS Cognito
COGNITO_REGION=ap-northeast-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ISSUER=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
